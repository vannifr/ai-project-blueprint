<div style="margin:0;padding:0;font-family:'Inter','Helvetica Neue',Arial,sans-serif;background:#ffffff;color:#1F2A44;display:flex;flex-direction:column;align-items:center;box-sizing:border-box;">
<div style="flex:1;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:60px 72px;box-sizing:border-box;width:100%;">
