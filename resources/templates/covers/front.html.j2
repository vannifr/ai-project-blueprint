<tr><td style="font-weight:700;color:#1F2A44;padding:2px 24px 2px 0;white-space:nowrap;border:none;background:none;">Standaard</td><td style="padding:2px 0;border:none;background:none;">PMI-CPMAI &middot; EU AI Act &middot; Agile-AI</td></tr>
<tr><td style="font-weight:700;color:#1F2A44;padding:2px 24px 2px 0;white-space:nowrap;border:none;background:none;">Licentie</td><td style="padding:2px 0;border:none;background:none;">CC BY-NC-SA 4.0</td></tr>
